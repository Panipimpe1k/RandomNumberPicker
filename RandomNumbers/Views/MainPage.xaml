<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RandomNumbers.Views.MainPage"
             Title="System losowania osoby"
             StyleClass="page">

    <VerticalStackLayout Spacing="10" Padding="10">

        <Picker x:Name="ClassPicker"
                StyleClass="classPicker"
                Title="Wybierz klasę"
                SelectedIndexChanged="OnClassChanged"/>

        <CollectionView x:Name="StudentsList" HeightRequest="200" SelectionMode="Single" StyleClass="studentsList">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="5" Margin="2" StyleId="StudentName">
                        <Label Text="{Binding .}" FontSize="16"/>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Entry x:Name="StudentEntry"
               StyleClass="studentsList"
               Placeholder="Imie i nazwisko ucznia"/>

        <HorizontalStackLayout Spacing="10">
            <Button Text="Dodaj" Clicked="OnAddStudent" StyleClass="mainButton"/>
            <Button Text="Usuń zaznaczonego" Clicked="OnRemoveStudent"/>
            <Button Text="Zapisz" Clicked="OnSave"/>
        </HorizontalStackLayout>

        <Button Text="Losuj osobę" Clicked="OnDrawStudent" StyleClass="drawButton"/>

        <Label x:Name="DrawnStudentLabel"
               StyleId="titleLabel"
               HorizontalOptions="Center"/>
    </VerticalStackLayout>
</ContentPage>
